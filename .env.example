# StatMind AI Environment Configuration

# App
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1
SECRET_KEY=dev-secret-key-change-in-production-statmind-ai

# Execution Sandbox
MAX_EXECUTION_MEMORY_MB=512
MAX_EXECUTION_TIME_SECONDS=60
SANDBOX_ENABLED=True

# OpenAI API (for Natural Language Intent Parsing & Chat Assistant)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# Database & Cache (for Docker Compose)
DATABASE_URL=postgresql://statmind:statmindpass@localhost:5432/statmind_db
REDIS_URL=redis://localhost:6379/0

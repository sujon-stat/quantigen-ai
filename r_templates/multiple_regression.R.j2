# ================================================================
# Multiple Linear Regression Analysis
# Generated by StatMind AI
# Dataset: {{ dataset_name }}
# Dependent Variable (Outcome): {{ dep_var }}
# Independent Variables (Predictors): {{ ind_vars | join(', ') }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(car)          # Variance Inflation Factor (vif) and Durbin-Watson test
library(broom)        # Tidy model outputs
library(lmtest)       # Breusch-Pagan test for heteroscedasticity

# --- Data Preparation ---
# Select outcome and predictors, then drop missing observations across these columns
predictors <- c({{ ind_vars | map('tojson') | join(', ') }})
analysis_data <- data %>%
  select(all_of(c({{ dep_var | tojson }}, predictors))) %>%
  drop_na()

cat("Analysis sample size: n =", nrow(analysis_data), "\n")
cat("Number of predictors: p =", length(predictors), "\n")

# --- Model Specification & Fit ---
# Construct model formula: Y ~ X1 + X2 + ... + Xk
formula_str <- paste({{ dep_var | tojson }}, "~", paste(predictors, collapse = " + "))
model_formula <- as.formula(formula_str)

ols_model <- lm(model_formula, data = analysis_data)
cat("\n--- Multiple Linear Regression OLS Model ---\n")
print(summary(ols_model))

# --- Multicollinearity Diagnostics (Variance Inflation Factor - VIF) ---
# VIF > 5 is problematic; VIF > 10 indicates severe multicollinearity
if (length(predictors) > 1) {
  cat("\n--- Variance Inflation Factor (VIF) ---\n")
  vif_vals <- car::vif(ols_model)
  print(vif_vals)
} else {
  cat("\n--- Single predictor model: VIF = 1.0 (No multicollinearity) ---\n")
}

# --- Residual Diagnostics ---
cat("\n--- Residual Diagnostics ---\n")
# 1. Normality of Residuals (Shapiro-Wilk)
shapiro_res <- shapiro.test(residuals(ols_model))
print(shapiro_res)

# 2. Homoscedasticity (Breusch-Pagan Test)
bp_res <- lmtest::bptest(ols_model)
print(bp_res)

# 3. Autocorrelation (Durbin-Watson Test)
dw_res <- car::durbinWatsonTest(ols_model)
print(dw_res)

# --- Model Performance Summary ---
model_summary <- broom::glance(ols_model)
cat("\n--- Model Performance Metrics ---\n")
cat("Multiple R-squared:", round(model_summary$r.squared, 4), "\n")
cat("Adjusted R-squared:", round(model_summary$adj.r.squared, 4), "\n")
cat("F-statistic:", round(model_summary$statistic, 2), "on", model_summary$df, "and", model_summary$df.residual, "DF, p-value:", format.pval(model_summary$p.value, digits = 4), "\n")

# --- Visualization: Predicted vs. Observed ---
analysis_data$predicted <- predict(ols_model)
analysis_data$residuals <- residuals(ols_model)

ggplot(analysis_data, aes(x = predicted, y = .data[[ {{ dep_var | tojson }} ]])) +
  geom_point(alpha = 0.6, color = "#2c3e50") +
  geom_abline(intercept = 0, slope = 1, color = "#e74c3c", linetype = "dashed", linewidth = 1) +
  labs(
    title = "Multiple Regression: Predicted vs. Observed Values",
    x = "Predicted Outcome (Model Fit)",
    y = paste("Observed Outcome (", {{ dep_var | tojson }}, ")")
  ) +
  theme_minimal()

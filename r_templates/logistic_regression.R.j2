# ================================================================
# Binary Logistic Regression Analysis
# Generated by StatMind AI
# Dataset: {{ dataset_name }}
# Binary Outcome Variable: {{ dep_var }}
# Predictor Variables: {{ ind_vars | join(', ') }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(car)          # Variance Inflation Factor (vif)
library(broom)        # Tidy model outputs
library(pscl)         # McFadden's Pseudo R-Squared

# --- Data Preparation ---
predictors <- c({{ ind_vars | map('tojson') | join(', ') }})
analysis_data <- data %>%
  select(all_of(c({{ dep_var | tojson }}, predictors))) %>%
  drop_na()

# Ensure dependent variable is binary (0 and 1)
unique_outcomes <- sort(unique(analysis_data[[ {{ dep_var | tojson }} ]]))
cat("Analysis sample size: n =", nrow(analysis_data), "\n")
cat("Binary outcome categories detected:", paste(unique_outcomes, collapse = ", "), "\n")

# --- Model Specification & Fit ---
# Generalized Linear Model with Binomial Family and Logit Link
formula_str <- paste({{ dep_var | tojson }}, "~", paste(predictors, collapse = " + "))
model_formula <- as.formula(formula_str)

logit_model <- glm(model_formula, data = analysis_data, family = binomial(link = "logit"))
cat("\n--- Binary Logistic Regression Model (Log-Odds Coefficients) ---\n")
print(summary(logit_model))

# --- Odds Ratios and 95% Confidence Intervals ---
# Exponentiate log-odds coefficients to obtain Odds Ratios (OR)
odds_ratios <- exp(coef(logit_model))
or_conf_int <- exp(confint.default(logit_model, level = {{ conf_level | default(0.95) }}))

or_table <- data.frame(
  Odds_Ratio = round(odds_ratios, 4),
  CI_Lower = round(or_conf_int[, 1], 4),
  CI_Upper = round(or_conf_int[, 2], 4),
  p_value = format.pval(summary(logit_model)$coefficients[, 4], digits = 4)
)
cat("\n--- Odds Ratios (OR = exp(beta)) and 95% Confidence Intervals ---\n")
print(or_table)
# Interpretation: OR > 1 indicates increased likelihood of event; OR < 1 indicates decreased likelihood. If 95% CI includes 1.0, the effect is not statistically significant at alpha = 0.05.

# --- Multicollinearity Diagnostics (VIF) ---
if (length(predictors) > 1) {
  cat("\n--- Variance Inflation Factor (VIF) ---\n")
  vif_vals <- car::vif(logit_model)
  print(vif_vals)
}

# --- Model Goodness of Fit ---
# McFadden's Pseudo R-Squared
null_model <- glm(as.formula(paste({{ dep_var | tojson }}, "~ 1")), data = analysis_data, family = binomial(link = "logit"))
mcfadden_r2 <- 1 - (logLik(logit_model) / logLik(null_model))
cat("\n--- Goodness of Fit ---\n")
cat("McFadden's Pseudo R-Squared:", round(as.numeric(mcfadden_r2), 4), "\n")
# Interpretation: McFadden's R2 values between 0.2 and 0.4 indicate excellent model fit

# Likelihood Ratio Chi-Square Test
lr_chisq <- logit_model$null.deviance - logit_model$deviance
lr_df <- logit_model$df.null - logit_model$df.residual
lr_pval <- pchisq(lr_chisq, lr_df, lower.tail = FALSE)
cat("Likelihood Ratio Chi-Square:", round(lr_chisq, 2), "on", lr_df, "DF, p-value:", format.pval(lr_pval, digits = 4), "\n")

# --- Visualization: Predicted Probability Distribution ---
analysis_data$predicted_prob <- predict(logit_model, type = "response")

ggplot(analysis_data, aes(x = predicted_prob, fill = as.factor(.data[[ {{ dep_var | tojson }} ]]))) +
  geom_density(alpha = 0.5) +
  labs(
    title = "Predicted Event Probability Distribution by Actual Binary Outcome",
    x = "Predicted Probability P(Outcome = 1)",
    y = "Density",
    fill = paste("Actual Outcome (", {{ dep_var | tojson }}, ")")
  ) +
  theme_minimal()

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(vcd)          # Visualizing categorical data and Cramer's V

# --- Data Preparation ---
analysis_data <- data %>%
  select({{ var1 }}, {{ var2 }}) %>%
  drop_na()

cat("Analysis sample size: n =", nrow(analysis_data), "\n")

# Create contingency table
cont_table <- table(analysis_data${{ var1 }}, analysis_data${{ var2 }})
cat("Observed Contingency Table:\n")
print(cont_table)

# --- Assumption Checks ---

## Expected Cell Frequencies check (all cells should be >= 5)
chi_test_raw <- chisq.test(cont_table)
cat("\nExpected Cell Frequencies Table:\n")
print(chi_test_raw$expected)
cells_below_5 <- sum(chi_test_raw$expected < 5)
cat("Cells with expected count < 5:", cells_below_5, "\n")
# Interpretation: If cells_below_5 > 0, consider collapsing categories or Fisher's Exact Test

# --- Main Analysis ---
print(chi_test_raw)

# --- Effect Size ---
# Cramer's V
cramers_v <- vcd::assocstats(cont_table)$cramer
cat("Cramer's V =", round(cramers_v, 3), "\n")
# Interpretation: Measures association strength from 0 (none) to 1 (perfect)

# --- Visualization ---
analysis_data %>%
  count({{ var1 }}, {{ var2 }}) %>%
  ggplot(aes(x = {{ var1 }}, y = n, fill = {{ var2 }})) +
  geom_bar(stat = "identity", position = "dodge", alpha = 0.85) +
  labs(
    title = "Contingency Counts: {{ var1 }} by {{ var2 }}",
    x = "{{ var1 }}",
    y = "Frequency"
  ) +
  theme_minimal()

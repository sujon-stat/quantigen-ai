# Simple Linear Regression Analysis
# Generated by StatMind AI
# Dataset: {{ dataset_name }}
# Outcome (Y): {{ dep_var }}, Predictor (X): {{ ind_var }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(car)          # Diagnostic tests (Durbin-Watson, VIF)
library(lmtest)       # Breusch-Pagan test for homoscedasticity
library(sandwich)     # Robust standard errors (HC3)

# --- Data Preparation ---
analysis_data <- data %>%
  select({{ dep_var }}, {{ ind_var }}) %>%
  drop_na()

cat("Analysis sample size: n =", nrow(analysis_data), "\n")

# Fit initial OLS Model
ols_model <- lm({{ dep_var }} ~ {{ ind_var }}, data = analysis_data)

# --- Assumption Checks ---

## 1. Homoscedasticity (Breusch-Pagan test)
bp_test <- lmtest::bptest(ols_model)
print(bp_test)
# Interpretation: p > 0.05 indicates constant error variance

## 2. Autocorrelation (Durbin-Watson test)
dw_test <- car::durbinWatsonTest(ols_model)
print(dw_test)
# Interpretation: Statistic near 2 indicates independence across observations

## 3. Normality of Residuals (Shapiro-Wilk)
shapiro_res <- shapiro.test(residuals(ols_model))
cat("Shapiro-Wilk on residuals: W =", round(shapiro_res$statistic, 4), ", p =", round(shapiro_res$p.value, 4), "\n")

# --- Main Analysis ---
# If Breusch-Pagan p < 0.05, robust SEs (HC3) are recommended
cat("\nStandard OLS Summary:\n")
print(summary(ols_model))

# --- Robust Inference (Auto-Fix for Heteroscedasticity) ---
robust_coefs <- lmtest::coeftest(ols_model, vcov = sandwich::vcovHC(ols_model, type = "HC3"))
cat("\nRobust Coefficients (HC3 Standard Errors):\n")
print(robust_coefs)

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ ind_var }}, y = {{ dep_var }})) +
  geom_point(alpha = 0.65, color = "#2E86AB", size = 2.5) +
  geom_smooth(method = "lm", color = "#C73E1D", fill = "#2E86AB", alpha = 0.15) +
  labs(
    title = "Linear Regression: {{ dep_var }} predicted by {{ ind_var }}",
    subtitle = paste0("R-squared = ", round(summary(ols_model)$r.squared, 3)),
    x = "{{ ind_var }}",
    y = "{{ dep_var }}"
  ) +
  theme_minimal()

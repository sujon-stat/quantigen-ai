# ================================================================
# Mann-Whitney U Test Analysis (Non-Parametric Two-Group Comparison)
# Generated by StatMind AI
# Dataset: {{ dataset_name }}
# Variables: Dependent = {{ dep_var }}, Grouping = {{ group_var }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(effectsize)   # Effect size calculations (Rank-biserial correlation)
library(broom)        # Tidy model outputs

# --- Data Preparation ---
analysis_data <- data %>%
  select({{ dep_var }}, {{ group_var }}) %>%
  drop_na() %>%
  mutate({{ group_var }} = as.factor({{ group_var }}))

# Sample size after cleaning
cat("Analysis sample size: n =", nrow(analysis_data), "\n")
group_summary <- analysis_data %>%
  group_by({{ group_var }}) %>%
  summarise(n = n(), median = median({{ dep_var }}), IQR = IQR({{ dep_var }}))
print(group_summary)

# --- Main Analysis ---
# Mann-Whitney U test (equivalent to Wilcoxon rank-sum test)
wilcox_res <- wilcox.test(
  {{ dep_var }} ~ {{ group_var }},
  data = analysis_data,
  exact = FALSE,
  conf.int = TRUE,
  conf.level = {{ conf_level | default(0.95) }}
)
cat("\n--- Mann-Whitney U / Wilcoxon Rank-Sum Test ---\n")
print(wilcox_res)
# Interpretation: p < 0.05 indicates a statistically significant difference in location (ranks/medians) between groups

# --- Effect Size ---
# Rank-biserial correlation (r_rb)
r_rb <- effectsize::rank_biserial({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
cat("\n--- Effect Size (Rank-Biserial Correlation) ---\n")
print(r_rb)
# Interpretation: |r_rb| < 0.1 = negligible, 0.1-0.3 = small, 0.3-0.5 = medium, > 0.5 = large

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ group_var }}, y = {{ dep_var }}, fill = {{ group_var }})) +
  geom_boxplot(alpha = 0.7, outlier.shape = 21, notch = TRUE) +
  geom_jitter(width = 0.15, alpha = 0.3, size = 1.5) +
  labs(
    title = "Median & Rank Distribution of {{ dep_var }} across {{ group_var }}",
    x = "{{ group_var }}",
    y = "{{ dep_var }}"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

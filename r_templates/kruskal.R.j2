# ================================================================
# Kruskal-Wallis Non-Parametric ANOVA
# Generated by Quantigen AI
# Dataset: {{ dataset_name }}
# Variables: Dependent = {{ dep_var }}, Grouping = {{ group_var }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(effectsize)   # Effect size calculations (Epsilon-squared)
library(broom)        # Tidy model outputs

# --- Data Preparation ---
analysis_data <- data %>%
  select({{ dep_var }}, {{ group_var }}) %>%
  drop_na() %>%
  mutate({{ group_var }} = as.factor({{ group_var }}))

# Sample size and medians across groups
cat("Analysis sample size: n =", nrow(analysis_data), "\n")
group_summary <- analysis_data %>%
  group_by({{ group_var }}) %>%
  summarise(n = n(), median = median({{ dep_var }}), IQR = IQR({{ dep_var }}))
print(group_summary)

# --- Main Analysis ---
# Kruskal-Wallis rank sum test across 3+ groups
kruskal_res <- kruskal.test({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
cat("\n--- Kruskal-Wallis H Test ---\n")
print(kruskal_res)
# Interpretation: p < 0.05 indicates at least one group's stochastic dominance / median differs significantly

# --- Effect Size ---
# Epsilon-squared (epsilon^2)
eps_res <- effectsize::epsilon_squared(kruskal_res)
cat("\n--- Effect Size (Epsilon-Squared) ---\n")
print(eps_res)
# Interpretation: epsilon^2 < 0.01 = negligible, 0.01-0.08 = small, 0.08-0.26 = medium, > 0.26 = large

# --- Post-Hoc Pairwise Comparisons (Dunn's Test with Bonferroni Correction) ---
# Conducted when omnibus Kruskal-Wallis test is statistically significant (p < 0.05)
if (requireNamespace("FSA", quietly = TRUE)) {
  dunn_res <- FSA::dunnTest({{ dep_var }} ~ {{ group_var }}, data = analysis_data, method = "bonferroni")
  cat("\n--- Dunn's Post-Hoc Pairwise Comparisons (Bonferroni Adjusted) ---\n")
  print(dunn_res)
} else {
  pairwise_wilcox <- pairwise.wilcox.test(analysis_data[[ "{{ dep_var }}" ]], analysis_data[[ "{{ group_var }}" ]], p.adjust.method = "bonferroni")
  cat("\n--- Pairwise Wilcoxon Rank Sum Tests (Bonferroni Adjusted) ---\n")
  print(pairwise_wilcox)
}

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ group_var }}, y = {{ dep_var }}, fill = {{ group_var }})) +
  geom_boxplot(alpha = 0.7, outlier.shape = 21, notch = FALSE) +
  geom_jitter(width = 0.15, alpha = 0.3, size = 1.5) +
  labs(
    title = "Rank/Median Distribution of {{ dep_var }} across {{ group_var }} Groups",
    x = "{{ group_var }}",
    y = "{{ dep_var }}"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

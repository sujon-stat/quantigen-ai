# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(car)          # Companion to Applied Regression (Levene's test)
library(effsize)      # Effect size calculations (Cohen's d)
library(broom)        # Tidy model outputs

# Safe Shapiro-Wilk helper (handles R limit of 5000 observations without crashing)
safe_shapiro <- function(x) {
  x_clean <- na.omit(x)
  if (length(x_clean) < 3) return(list(statistic = NA, p.value = NA))
  if (length(x_clean) > 5000) {
    set.seed(42)
    x_clean <- sample(x_clean, 5000)
  }
  shapiro.test(x_clean)
}

# --- Data Preparation ---
# Remove missing values for this analysis
analysis_data <- data %>%
  select({{ dep_var }}, {{ group_var }}) %>%
  drop_na()

# Sample size after cleaning
cat("Analysis sample size: n =", nrow(analysis_data), "\n")

# --- Assumption Checks ---

## 1. Normality (Shapiro-Wilk test per group)
normality_results <- analysis_data %>%
  group_by({{ group_var }}) %>%
  summarise(
    n = n(),
    shapiro_W = safe_shapiro({{ dep_var }})$statistic,
    shapiro_p = safe_shapiro({{ dep_var }})$p.value
  )
print(normality_results)
# Interpretation: p > 0.05 suggests normality is not violated

## 2. Homogeneity of Variance (Levene's test)
levene_result <- car::leveneTest({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
print(levene_result)
# Interpretation: p > 0.05 suggests equal variances across groups

# --- Main Analysis ---
# var.equal is set based on Levene's test / Welch's auto-correction
ttest_result <- t.test(
  {{ dep_var }} ~ {{ group_var }},
  data = analysis_data,
  var.equal = {{ var_equal | default('FALSE') }},
  conf.level = {{ conf_level | default(0.95) }}
)
print(ttest_result)

# --- Effect Size ---
# Cohen's d with 95% Confidence Interval
d_result <- effsize::cohen.d({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
cat("Cohen's d =", round(d_result$estimate, 3), "\n")
cat("95% CI:", round(d_result$conf.int[1], 3), "to", round(d_result$conf.int[2], 3), "\n")
# Interpretation: |d| < 0.2 = negligible, 0.2-0.5 = small, 0.5-0.8 = medium, > 0.8 = large

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ group_var }}, y = {{ dep_var }}, fill = {{ group_var }})) +
  geom_boxplot(alpha = 0.7, outlier.shape = 21) +
  geom_jitter(width = 0.15, alpha = 0.3, size = 1.5) +
  stat_summary(fun = "mean", geom = "point", shape = 23, size = 3, fill = "white") +
  labs(
    title = "Distribution of {{ dep_var }} by {{ group_var }}",
    x = "{{ group_var }}",
    y = "{{ dep_var }}"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

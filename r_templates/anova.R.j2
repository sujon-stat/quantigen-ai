# ================================================================
# One-Way ANOVA Analysis
# Generated by StatMind AI
# Dataset: {{ dataset_name }}
# Variables: Dependent = {{ dep_var }}, Grouping = {{ group_var }}
# Date: {{ timestamp }}
# ================================================================

# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(car)          # Companion to Applied Regression (Levene's test)
library(effectsize)   # Effect size calculations (Eta-squared, Omega-squared)
library(broom)        # Tidy model outputs

# --- Data Preparation ---
# Remove missing values for this analysis and ensure grouping variable is a factor
analysis_data <- data %>%
  select({{ dep_var }}, {{ group_var }}) %>%
  drop_na() %>%
  mutate({{ group_var }} = as.factor({{ group_var }}))

# Sample size after cleaning
cat("Analysis sample size: n =", nrow(analysis_data), "\n")
cat("Number of groups: k =", n_distinct(analysis_data[[ "{{ group_var }}" ]]), "\n")

# --- Assumption Checks ---

## 1. Normality (Shapiro-Wilk test per group)
normality_results <- analysis_data %>%
  group_by({{ group_var }}) %>%
  summarise(
    n = n(),
    shapiro_W = shapiro.test({{ dep_var }})$statistic,
    shapiro_p = shapiro.test({{ dep_var }})$p.value
  )
print(normality_results)
# Interpretation: p > 0.05 suggests normality within group is not violated

## 2. Homogeneity of Variance (Levene's test)
levene_result <- car::leveneTest({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
print(levene_result)
# Interpretation: p > 0.05 suggests equal variances across all groups

# --- Main Analysis ---
# Standard OLS ANOVA (when equal variance holds)
anova_model <- aov({{ dep_var }} ~ {{ group_var }}, data = analysis_data)
cat("\n--- Standard One-Way ANOVA ---\n")
print(summary(anova_model))

# Welch's ANOVA (robust when Levene's test p < 0.05 / unequal variances)
welch_anova <- oneway.test({{ dep_var }} ~ {{ group_var }}, data = analysis_data, var.equal = FALSE)
cat("\n--- Welch's ANOVA (Robust to Unequal Variances) ---\n")
print(welch_anova)

# --- Effect Size ---
# Eta-squared and Omega-squared
eta_res <- effectsize::eta_squared(anova_model, partial = FALSE)
omega_res <- effectsize::omega_squared(anova_model, partial = FALSE)
cat("\n--- Effect Sizes ---\n")
print(eta_res)
print(omega_res)
# Interpretation: Eta2 / Omega2 < 0.01 = negligible, 0.01-0.06 = small, 0.06-0.14 = medium, > 0.14 = large

# --- Post-Hoc Pairwise Comparisons (Tukey's HSD) ---
# Conducted when F-test is statistically significant (p < 0.05)
tukey_res <- TukeyHSD(anova_model, conf.level = {{ conf_level | default(0.95) }})
cat("\n--- Tukey's HSD Pairwise Comparisons ---\n")
print(tukey_res)

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ group_var }}, y = {{ dep_var }}, fill = {{ group_var }})) +
  geom_boxplot(alpha = 0.7, outlier.shape = 21) +
  geom_jitter(width = 0.15, alpha = 0.3, size = 1.5) +
  stat_summary(fun = "mean", geom = "point", shape = 23, size = 3, fill = "white") +
  labs(
    title = "Distribution of {{ dep_var }} across {{ group_var }} Groups",
    x = "{{ group_var }}",
    y = "{{ dep_var }}"
  ) +
  theme_minimal() +
  theme(legend.position = "none")

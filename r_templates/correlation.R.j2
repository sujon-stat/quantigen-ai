# --- Setup ---
library(tidyverse)    # Data manipulation and visualization
library(Hmisc)        # Correlation matrix with exact p-values
library(broom)        # Tidy statistical summaries

# Safe Shapiro-Wilk function (handles R limit of 5000 observations without crashing)
safe_shapiro <- function(x) {
  x_clean <- na.omit(x)
  if (length(x_clean) < 3) return(list(statistic = NA, p.value = NA))
  if (length(x_clean) > 5000) {
    set.seed(42)
    x_clean <- sample(x_clean, 5000)
  }
  shapiro.test(x_clean)
}

# --- Data Preparation ---
analysis_data <- data %>%
  select({{ var1 }}, {{ var2 }}) %>%
  drop_na()

cat("Analysis sample size: n =", nrow(analysis_data), "\n")

# --- Assumption Checks ---

## 1. Bivariate Normality (Shapiro-Wilk test on both variables)
shapiro_v1 <- safe_shapiro(analysis_data${{ var1 }})
shapiro_v2 <- safe_shapiro(analysis_data${{ var2 }})
cat("Shapiro-Wilk for {{ var1 }}: W =", round(shapiro_v1$statistic, 4), ", p =", round(shapiro_v1$p.value, 4), "\n")
cat("Shapiro-Wilk for {{ var2 }}: W =", round(shapiro_v2$statistic, 4), ", p =", round(shapiro_v2$p.value, 4), "\n")

# --- Main Analysis ---
cor_result <- cor.test(
  analysis_data${{ var1 }},
  analysis_data${{ var2 }},
  method = "pearson",
  conf.level = {{ conf_level | default(0.95) }}
)
print(cor_result)

# --- Effect Size & Interpretation ---
r_val <- cor_result$estimate
cat("Pearson r =", round(r_val, 3), "\n")
cat("95% CI:", round(cor_result$conf.int[1], 3), "to", round(cor_result$conf.int[2], 3), "\n")
# Interpretation: |r| < 0.1 = negligible, 0.1-0.3 = small, 0.3-0.5 = medium, > 0.5 = large

# --- Visualization ---
ggplot(analysis_data, aes(x = {{ var1 }}, y = {{ var2 }})) +
  geom_point(alpha = 0.6, color = "#2E86AB", size = 2.5) +
  geom_smooth(method = "lm", color = "#C73E1D", fill = "#2E86AB", alpha = 0.15) +
  labs(
    title = "Scatter Plot of {{ var1 }} vs {{ var2 }}",
    subtitle = paste0("Pearson r = ", round(r_val, 2), ", p = ", round(cor_result$p.value, 3)),
    x = "{{ var1 }}",
    y = "{{ var2 }}"
  ) +
  theme_minimal()
